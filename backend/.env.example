# Required in production. Use a long random value.
MEOWMORY_JWT_SECRET=replace-with-a-long-random-secret

# PostgreSQL connection. Example for the included docker compose service.
MEOWMORY_DATABASE_URL=postgresql+psycopg2://meowmory:meowmory@localhost:5432/meowmory

# Redis cache/broker for health checks, cached reads, and async story generation.
MEOWMORY_REDIS_URL=redis://localhost:6379/0

# Google Cloud OAuth client ID, used by both backend token verification and frontend GIS button.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
